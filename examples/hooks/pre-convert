#!/bin/bash
# ==============================================================================
# Hook: pre-convert
# Description: Runs before conversion starts - useful for backups, notifications,
#              or custom preparation steps
# ==============================================================================

CTID="$1"
VMID="$2"

# Environment variables available:
# HOOK_CTID, HOOK_VMID, HOOK_LOG_FILE, HOOK_STAGE

echo "[$(date '+%Y-%m-%d %H:%M:%S')] Pre-convert hook: Preparing CT $CTID for conversion to VM $VMID" | tee -a "$HOOK_LOG_FILE"

# Example 1: Send notification (uncomment to use)
# curl -s -X POST "https://ntfy.sh/my-topic" \
#     -d "Starting conversion: CT $CTID → VM $VMID"

# Example 2: Create external backup before conversion
# BACKUP_DIR="/backup/pre-convert/$(date +%Y%m%d)"
# mkdir -p "$BACKUP_DIR"
# vzdump "$CTID" --dumpdir "$BACKUP_DIR" --compress zstd

# Example 3: Record start time for metrics
# echo "$(date +%s)" > "/tmp/convert-start-${CTID}.timestamp"

# Example 4: Verify container is stopped for consistent state
STATUS=$(pct status "$CTID" 2>/dev/null | awk '{print $2}')
if [[ "$STATUS" != "stopped" ]]; then
    echo "Warning: Container $CTID is running. Stopping for consistent copy..."
    pct stop "$CTID" 2>/dev/null || true
    sleep 3
fi

echo "[$(date '+%Y-%m-%d %H:%M:%S')] Pre-convert hook completed" | tee -a "$HOOK_LOG_FILE"
exit 0
