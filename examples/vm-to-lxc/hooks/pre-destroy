#!/bin/bash
# ==============================================================================
# vm-to-lxc.sh — Example Hook: pre-destroy
# ==============================================================================
# Runs BEFORE destroying the source VM (only when --destroy-source is used).
# Use this for final backups, audit logging, or safety checks.
#
# Arguments:
#   $1 = Source VM ID (VMID)
#   $2 = Target Container ID (CTID)
