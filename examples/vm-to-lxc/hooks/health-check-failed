#!/bin/bash
# ==============================================================================
# vm-to-lxc.sh — Example Hook: health-check-failed
# ==============================================================================
# Runs when post-conversion health checks detect issues with the new container.
# Use this for alerting, diagnostics collection, or automatic remediation.
#
# Arguments:
#   $1 = Source VM ID (VMID)
#   $2 = Target Container ID (CTID)
#
# Environment variables available:
#   HOOK_VMID      — Source VM ID
#   HOOK_CTID      — Target container ID
#   HOOK_LOG_FILE  — Path to conversion log file
#   HOOK_STAGE     — Hook stage name (health-check-failed)
# ==============================================================================

VMID="${1:-$HOOK_VMID}"
CTID="${2:-$HOOK_CTID}"

echo "[health-check-failed] Health check issues detected for CT $CTID (from VM $VMID)"
echo "[health-check-failed] Timestamp: $(date -Is)"

